---
import Container from './container.astro';
import Section from './section.astro';

export interface RelatedItem {
  title: string;
  description: string;
  url: string;
  image?: string;
}

export interface Props {
  title?: string;
  items: RelatedItem[];
  class?: string;
}

const {
  title = 'Related Content',
  items,
  class: className = '',
} = Astro.props;
---

<Section class:list={['bg-gray-50', className]}>
  <Container>
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 text-center">
        {title}
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item) => (
          <a
            href={item.url}
            class="group bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow"
          >
            {item.image && (
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-5">
              <h3 class="font-semibold text-gray-900 mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {item.title}
              </h3>
              <p class="text-sm text-gray-600 line-clamp-2">
                {item.description}
              </p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary group-hover:gap-2 transition-all">
                Learn more
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </Container>
</Section>
