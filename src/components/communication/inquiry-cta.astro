---
import Container from '../ui/container.astro';
import Section from '../ui/section.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';

// 使用 Astro 内置 i18n 检测当前语言
const currentLocale = Astro.currentLocale || 'zh';
const isEnglish = currentLocale === 'en';

const content = isEnglish ? {
  subtitle: 'Get Started',
  title: 'Ready to Build Your Lead Generation System?',
  description: 'Fill out the form for a free project evaluation and quote. Our design experts will contact you within 24 hours.',
  ctaPrimary: 'Get Free Quote',
  ctaSecondary: 'Email Us',
  phoneLabel: 'Or call us at:',
  contactPath: getRelativeLocaleUrl('en', 'contact'),
} : {
  subtitle: 'Get Started',
  title: '准备好打造您的独立站了吗？',
  description: '填写表单获取免费项目评估和报价，我们的设计专家将在24小时内与您联系',
  ctaPrimary: '获取免费报价',
  ctaSecondary: '发送邮件咨询',
  phoneLabel: '或直接拨打：',
  contactPath: getRelativeLocaleUrl('zh', 'contact'),
};
---

<Section class="bg-stone-900 text-stone-300">
  <Container>
    <div class="text-center max-w-2xl mx-auto py-8">
      <span class="inline-block text-xs tracking-widest text-stone-500 uppercase mb-4">{content.subtitle}</span>
      <h2 class="text-3xl font-light text-stone-100 mb-4">
        {content.title}
      </h2>
      <p class="text-stone-400 mb-8">
        {content.description}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={content.contactPath}
          class="inline-flex items-center gap-2 px-8 py-3 bg-stone-100 text-stone-800 font-medium rounded hover:bg-white transition-colors"
        >
          <span>{content.ctaPrimary}</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="mailto:hello@xunpanyun.com"
          class="inline-flex items-center gap-2 px-8 py-3 text-stone-400 font-medium rounded hover:text-stone-200 transition-colors border border-stone-700 hover:border-stone-600"
        >
          <span>{content.ctaSecondary}</span>
        </a>
      </div>
      <p class="mt-6 text-sm text-stone-500">
        {content.phoneLabel}<a href="tel:+864008888888" class="text-stone-300 hover:text-stone-100">+86 400-888-8888</a>
      </p>
    </div>
  </Container>
</Section>
