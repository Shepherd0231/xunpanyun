---
/**
 * Analytics Component
 * 
 * Handles Google Analytics 4 (GA4) and Google Search Console (GSC) integration.
 * Only renders tracking codes when PUBLIC_GA_ID is configured.
 * 
 * Environment Variables:
 * - PUBLIC_GA_ID: Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
 * - PUBLIC_GSC_ID: Google Search Console Verification ID (optional)
 */

const gaId = import.meta.env.PUBLIC_GA_ID || '';
const gscId = import.meta.env.PUBLIC_GSC_ID || '';
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || '';
const baiduId = import.meta.env.PUBLIC_BAIDU_ID || '';

// Check if analytics should be enabled
const isEnabled = Boolean(gaId);
---

{isEnabled && (
  <>
    <!-- Google Analytics 4 -->
    <script is:inline define:vars={{ gaId }}>
      // Google Analytics 4 initialization
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', gaId, {
        send_page_view: true,
        cookie_flags: 'SameSite=None;Secure',
        cookie_expires: 63072000, // 2 years
        cookie_update: false,
      });
    </script>
    
    <!-- GA4 Script -->
    <script 
      is:inline 
      async 
      src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
    />
    
    <!-- Page View Tracking for SPA navigation -->
    <script is:inline define:vars={{ gaId }}>
      // Track page views on client-side navigation
      document.addEventListener('astro:page-load', () => {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'page_view', {
            page_location: window.location.href,
            page_path: window.location.pathname,
            page_title: document.title,
          });
        }
      });
    </script>
  </>
)}

{gscId && (
  <meta name="google-site-verification" content={gscId} />
)}

{clarityId && (
  <script is:inline define:vars={{ clarityId }}>
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", clarityId);
  </script>
)}

{baiduId && (
  <script is:inline define:vars={{ baiduId }}>
    var _hmt = _hmt || [];
    (function() {
      var hm = document.createElement("script");
      hm.src = "https://hm.baidu.com/hm.js?" + baiduId;
      var s = document.getElementsByTagName("script")[0]; 
      s.parentNode.insertBefore(hm, s);
    })();
  </script>
)}
