---
import Container from '../ui/container.astro';

const navLinks = [
  { href: '/products', label: 'Products' },
  { href: '/services', label: 'Services' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About Us' },
];

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '+8612345678900';
const whatsappLink = `https://wa.me/${whatsappNumber.replace(/\D/g, '')}`;

// Language configuration
const languages = [
  { code: 'en', label: 'EN', name: 'English' },
  { code: 'zh', label: '中文', name: 'Chinese' },
  { code: 'de', label: 'DE', name: 'German' },
];

// Get current locale from URL
const currentPath = Astro.url.pathname;
const currentLocale = currentPath.startsWith('/zh') ? 'zh' : currentPath.startsWith('/de') ? 'de' : 'en';

// Build language switch URLs
function getLocaleUrl(locale: string): string {
  if (locale === 'en') {
    // Remove locale prefix for default language
    return currentPath.replace(/^\/(zh|de)\//, '/');
  }
  if (currentLocale === 'en') {
    // Add locale prefix
    return `/${locale}${currentPath}`;
  }
  // Replace locale prefix
  return currentPath.replace(/^\/(zh|de)\//, `/${locale}/`);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <Container>
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900">
        <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <span>YourBrand</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-600 hover:text-primary transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right Actions -->
      <div class="flex items-center gap-4">
        <!-- Language Switcher -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-gray-700 hover:text-primary transition-colors"
            aria-label="Select language"
          >
            <span>{languages.find(l => l.code === currentLocale)?.label || 'EN'}</span>
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-1 py-1 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all min-w-[120px]">
            {languages.map((lang) => (
              <a
                href={getLocaleUrl(lang.code)}
                class={`block px-4 py-2 text-sm hover:bg-gray-50 transition-colors ${
                  currentLocale === lang.code ? 'text-primary font-medium' : 'text-gray-700'
                }`}
              >
                {lang.name}
              </a>
            ))}
          </div>
        </div>

        <!-- WhatsApp Icon -->
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center justify-center w-10 h-10 rounded-full bg-green-500 text-white hover:bg-green-600 transition-colors"
          aria-label="Contact us on WhatsApp"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>

        <!-- Contact Button -->
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
        >
          <span>Contact Us</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="md:hidden p-2 text-gray-600 hover:text-gray-900"
          aria-label="Open menu"
          data-mobile-menu-toggle
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav class="hidden md:hidden py-4 border-t border-gray-100" data-mobile-menu>
      <div class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-600 hover:text-primary transition-colors font-medium py-2"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-blue-700 transition-colors mt-2"
        >
          <span>Contact Us</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </nav>
  </Container>
</header>

<script>
  const toggleBtn = document.querySelector('[data-mobile-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
