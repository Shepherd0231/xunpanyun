---
import Container from '../ui/container.astro';

// Get current locale from Astro
const currentLocale = Astro.currentLocale || 'zh';
const isEnglish = currentLocale === 'en';

// Navigation links based on locale - manual URL construction to avoid trailing slash issues
const navLinks = isEnglish ? [
  { href: '/en/', label: 'Home' },
  { href: '/en/about/', label: 'About' },
  { href: '/en/services/', label: 'Services' },
  { href: '/en/cases/', label: 'Cases' },
  { href: '/en/blog/', label: 'Blog' },
  { href: '/en/contact/', label: 'Contact' },
] : [
  { href: '/', label: '首页' },
  { href: '/about/', label: '关于我们' },
  { href: '/services/', label: '服务' },
  { href: '/cases/', label: '案例' },
  { href: '/blog/', label: '博客' },
  { href: '/contact/', label: '联系我们' },
];

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '+8612345678900';
const whatsappLink = `https://wa.me/${whatsappNumber.replace(/\D/g, '')}`;

// Language configuration
const languages = [
  { code: 'zh', label: '中文', name: 'Chinese' },
  { code: 'en', label: 'EN', name: 'English' },
];

// Build language switch URLs
function getLocaleUrl(locale: string): string {
  const currentPath = Astro.url.pathname;
  
  // If current path starts with /en/, remove it for Chinese version
  // If current path doesn't start with /en/, add it for English version
  if (locale === 'zh') {
    // Switch to Chinese: remove /en/ prefix
    return currentPath.replace(/^\/en\//, '/') || '/';
  } else {
    // Switch to English: add /en/ prefix
    if (currentPath.startsWith('/en/')) {
      return currentPath;
    }
    return '/en' + currentPath;
  }
}

const ctaText = isEnglish ? 'Free Consultation' : '免费咨询';
const logoAlt = isEnglish ? 'InquiryCloud' : '询盘云';
const homeLink = isEnglish ? '/en/' : '/';
const contactLink = isEnglish ? '/en/contact/' : '/contact/';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-stone-100">
  <Container>
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={homeLink} class="flex items-center gap-3">
        <img src="/logo.svg" alt={logoAlt} class="h-9 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-stone-500 hover:text-stone-800 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 px-2 py-1 text-sm text-stone-500 hover:text-stone-800 transition-colors"
            aria-label="Select language"
          >
            <span>{languages.find(l => l.code === currentLocale)?.label || '中文'}</span>
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-1 py-1 bg-white rounded border border-stone-100 shadow-sm opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all min-w-[100px]">
            {languages.map((lang) => (
              <a
                href={getLocaleUrl(lang.code)}
                class={`block px-3 py-1.5 text-sm hover:bg-stone-50 transition-colors ${
                  currentLocale === lang.code ? 'text-stone-800 font-medium' : 'text-stone-500'
                }`}
              >
                {lang.name}
              </a>
            ))}
          </div>
        </div>

        <!-- WhatsApp Icon -->
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center justify-center w-8 h-8 rounded text-stone-400 hover:text-teal-600 transition-colors"
          aria-label="Contact us on WhatsApp"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>

        <!-- Contact Button -->
        <a
          href={contactLink}
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 bg-stone-800 text-white text-sm font-medium rounded hover:bg-stone-700 transition-colors"
        >
          <span>{ctaText}</span>
        </a>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded text-stone-500 hover:text-stone-800 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6 menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg class="w-6 h-6 close-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="hidden md:hidden py-4 border-t border-stone-100">
      <div class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-stone-500 hover:text-stone-800 transition-colors py-2"
          >
            {link.label}
          </a>
        ))}
        <a
          href={contactLink}
          class="inline-flex items-center justify-center gap-1.5 px-4 py-2 bg-stone-800 text-white text-sm font-medium rounded hover:bg-stone-700 transition-colors mt-2"
        >
          <span>{ctaText}</span>
        </a>
      </div>
    </nav>
  </Container>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuBtn?.querySelector('.menu-icon');
  const closeIcon = menuBtn?.querySelector('.close-icon');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Close mobile menu when clicking on a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
