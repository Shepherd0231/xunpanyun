---
import Container from '../ui/container.astro';

// Get current locale from Astro
const currentLocale = Astro.currentLocale || 'zh';
const isEnglish = currentLocale === 'en';

// Content based on locale - using direct URL construction
const content = isEnglish ? {
  services: {
    title: 'Services',
    links: [
      { label: 'Lead Gen System', href: '/en/services/' },
      { label: 'Custom Development', href: '/en/services/' },
      { label: 'SEO Optimization', href: '/en/services/' },
      { label: 'Content Support', href: '/en/services/' },
    ],
  },
  company: {
    title: 'Company',
    links: [
      { label: 'About Us', href: '/en/about/' },
      { label: 'Case Studies', href: '/en/cases/' },
      { label: 'Blog', href: '/en/blog/' },
      { label: 'Contact', href: '/en/contact/' },
    ],
  },
  support: {
    title: 'Support',
    links: [
      { label: 'Help Center', href: '#' },
      { label: 'Documentation', href: '#' },
      { label: 'FAQ', href: '#' },
      { label: 'After Sales', href: '#' },
    ],
  },
  contact: {
    title: 'Contact',
    phone: '+86 400-888-8888',
    email: 'hello@xunpanyun.com',
    address: 'Nanshan District, Shenzhen, China',
  },
  brand: {
    description: 'InquiryCloud specializes in building high-conversion, scalable, and sustainable foreign trade lead generation website systems, helping businesses continuously acquire quality leads.',
    logoAlt: 'InquiryCloud',
  },
  bottom: {
    copyright: '© 2024 询盘云 InquiryCloud. All rights reserved.',
    privacy: 'Privacy Policy',
    terms: 'Terms of Service',
    sitemap: 'Sitemap',
    langZh: '中文',
    langEn: 'English',
  },
} : {
  services: {
    title: '服务项目',
    links: [
      { label: '外贸获客系统', href: '/services/' },
      { label: '网站定制开发', href: '/services/' },
      { label: 'SEO优化服务', href: '/services/' },
      { label: '内容运营支持', href: '/services/' },
    ],
  },
  company: {
    title: '关于公司',
    links: [
      { label: '关于我们', href: '/about/' },
      { label: '成功案例', href: '/cases/' },
      { label: '博客资讯', href: '/blog/' },
      { label: '联系我们', href: '/contact/' },
    ],
  },
  support: {
    title: '帮助支持',
    links: [
      { label: '帮助中心', href: '#' },
      { label: '使用文档', href: '#' },
      { label: '常见问题', href: '#' },
      { label: '售后服务', href: '#' },
    ],
  },
  contact: {
    title: '联系方式',
    phone: '+86 400-888-8888',
    email: 'hello@xunpanyun.com',
    address: '深圳市南山区科技园',
  },
  brand: {
    description: '询盘云专注于打造高转化、可规模增长、可长期运营的外贸获客型网站系统，帮助企业持续获取高质量询盘。',
    logoAlt: '询盘云',
  },
  bottom: {
    copyright: '© 2024 询盘云 InquiryCloud. All rights reserved.',
    privacy: '隐私政策',
    terms: '服务条款',
    sitemap: '网站地图',
    langZh: '中文',
    langEn: 'English',
  },
};

const homeLink = isEnglish ? '/en/' : '/';

// Language switch URLs
const currentPath = Astro.url.pathname;
const zhLink = currentPath.replace(/^\/en\//, '/') || '/';
const enLink = currentPath.startsWith('/en/') ? currentPath : '/en' + currentPath;
---

<footer class="bg-stone-900 text-stone-300">
  <Container>
    <div class="py-12 lg:py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Brand Column -->
        <div class="lg:col-span-2">
          <a href={homeLink} class="inline-block mb-6">
            <img src="/logo.svg" alt={content.brand.logoAlt} class="h-10 w-auto brightness-0 invert" />
          </a>
          <p class="text-stone-400 text-sm leading-relaxed mb-6 max-w-sm">
            {content.brand.description}
          </p>
          <div class="flex items-center gap-4">
            <a href="#" class="w-9 h-9 rounded bg-stone-800 flex items-center justify-center hover:bg-teal-600 transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.27-.027-.407-.032zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"/>
              </svg>
            </a>
            <a href="#" class="w-9 h-9 rounded bg-stone-800 flex items-center justify-center hover:bg-teal-600 transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
              </svg>
            </a>
            <a href="#" class="w-9 h-9 rounded bg-stone-800 flex items-center justify-center hover:bg-teal-600 transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Services -->
        <div>
          <h4 class="text-white font-medium mb-4">{content.services.title}</h4>
          <ul class="space-y-3">
            {content.services.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-stone-400 hover:text-teal-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="text-white font-medium mb-4">{content.company.title}</h4>
          <ul class="space-y-3">
            {content.company.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-stone-400 hover:text-teal-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="text-white font-medium mb-4">{content.contact.title}</h4>
          <ul class="space-y-3 text-sm text-stone-400">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 text-teal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{content.contact.phone}</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 text-teal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{content.contact.email}</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 text-teal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{content.contact.address}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-stone-800 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-stone-500">
          {content.bottom.copyright}
        </p>
        <div class="flex items-center gap-6 text-sm text-stone-500">
          <a href={isEnglish ? '/en/privacy/' : '/privacy/'} class="hover:text-stone-300 transition-colors">{content.bottom.privacy}</a>
          <a href={isEnglish ? '/en/terms/' : '/terms/'} class="hover:text-stone-300 transition-colors">{content.bottom.terms}</a>
          <a href={isEnglish ? '/en/sitemap/' : '/sitemap/'} class="hover:text-stone-300 transition-colors">{content.bottom.sitemap}</a>
          <span class="text-stone-600">|</span>
          <div class="flex items-center gap-2">
            <a href={zhLink} class={isEnglish ? 'hover:text-stone-300 transition-colors' : 'text-teal-400 font-medium'}>{content.bottom.langZh}</a>
            <span class="text-stone-600">/</span>
            <a href={enLink} class={isEnglish ? 'text-teal-400 font-medium' : 'hover:text-stone-300 transition-colors'}>{content.bottom.langEn}</a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</footer>
