---
import Layout from '../../components/layout/layout.astro';
import Container from '../../components/ui/container.astro';
import Section from '../../components/ui/section.astro';
import Breadcrumbs from '../../components/ui/breadcrumbs.astro';
import SmartImage from '../../components/media/smart-image.astro';
import RelatedContent from '../../components/ui/related-content.astro';
import InquiryCTA from '../../components/communication/inquiry-cta.astro';
import SEO from '../../components/seo/seo.astro';
import Schema from '../../components/seo/schema.astro';
import { slugify } from '../../utils/slugify';

// Placeholder blog data - replace with CMS integration
const posts = [
  {
    id: '1',
    title: 'The Future of CNC Machining: Trends to Watch in 2024',
    excerpt: 'Explore the latest advancements in CNC technology including AI integration, sustainable manufacturing, and multi-axis capabilities.',
    content: `
      <p>CNC machining has undergone remarkable transformation over the past decade. As we move into 2024, several key trends are shaping the future of precision manufacturing.</p>
      
      <h2>AI and Machine Learning Integration</h2>
      <p>Artificial intelligence is revolutionizing CNC machining by optimizing tool paths, predicting maintenance needs, and reducing material waste. Smart CNC systems can now self-adjust parameters in real-time based on sensor feedback.</p>
      
      <h2>Sustainable Manufacturing Practices</h2>
      <p>Environmental consciousness is driving innovation in CNC machining. From energy-efficient machines to coolant recycling systems, manufacturers are adopting greener practices without compromising precision.</p>
      
      <h2>Multi-Axis Machining Evolution</h2>
      <p>5-axis and even 9-axis CNC machines are becoming more accessible, enabling complex geometries that were previously impossible or required multiple setups.</p>
      
      <h2>Conclusion</h2>
      <p>The CNC machining industry continues to evolve rapidly. Staying informed about these trends helps manufacturers remain competitive and deliver superior quality to their clients.</p>
    `,
    image: 'https://images.unsplash.com/photo-1565043666747-69f6646db940?w=1200&q=80',
    author: 'John Smith',
    authorTitle: 'Senior Engineer',
    datePublished: '2024-01-15',
    category: 'Industry Insights',
    tags: ['CNC', 'Manufacturing', 'Technology'],
  },
  {
    id: '2',
    title: 'Choosing the Right Material for Your Metal Fabrication Project',
    excerpt: 'A comprehensive guide to selecting materials based on strength, corrosion resistance, cost, and application requirements.',
    content: `
      <p>Material selection is one of the most critical decisions in any metal fabrication project. The right choice can mean the difference between a product that lasts decades and one that fails prematurely.</p>
      
      <h2>Carbon Steel: The Workhorse</h2>
      <p>Carbon steel remains the most widely used material in fabrication due to its excellent strength-to-cost ratio. It's ideal for structural applications where weight isn't a primary concern.</p>
      
      <h2>Stainless Steel: Corrosion Resistance</h2>
      <p>When corrosion resistance is paramount, stainless steel is the go-to choice. Different grades offer varying levels of protection and cost points.</p>
      
      <h2>Aluminum: Lightweight Champion</h2>
      <p>For applications where weight matters, aluminum provides excellent strength-to-weight ratio along with natural corrosion resistance.</p>
      
      <h2>Conclusion</h2>
      <p>Understanding your application's requirements—load, environment, budget, and timeline—is essential for making the right material choice.</p>
    `,
    image: 'https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?w=1200&q=80',
    author: 'Sarah Chen',
    authorTitle: 'Materials Specialist',
    datePublished: '2024-01-10',
    category: 'Technical Guide',
    tags: ['Materials', 'Fabrication', 'Engineering'],
  },
  {
    id: '3',
    title: 'Quality Control in Manufacturing: Best Practices',
    excerpt: 'Learn how leading manufacturers maintain consistent quality through inspection protocols, documentation, and continuous improvement.',
    content: `
      <p>Quality control is the backbone of successful manufacturing operations. Implementing robust QC processes ensures customer satisfaction and reduces costly rework.</p>
      
      <h2>Incoming Material Inspection</h2>
      <p>Quality begins with raw materials. Establishing strict incoming inspection protocols prevents defective materials from entering the production process.</p>
      
      <h2>In-Process Quality Checks</h2>
      <p>Regular inspections during production catch issues early, when they're less expensive to correct. Statistical process control (SPC) helps identify trends before they become problems.</p>
      
      <h2>Final Inspection and Testing</h2>
      <p>Comprehensive final inspection ensures that only products meeting specifications leave the facility. This includes dimensional checks, functional testing, and visual inspection.</p>
      
      <h2>Documentation and Traceability</h2>
      <p>Complete documentation provides traceability and supports continuous improvement efforts. Digital quality management systems are becoming the industry standard.</p>
      
      <h2>Conclusion</h2>
      <p>Quality control is not a destination but a journey of continuous improvement. The best manufacturers view QC as an investment rather than a cost.</p>
    `,
    image: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=1200&q=80',
    author: 'Michael Wang',
    authorTitle: 'Quality Manager',
    datePublished: '2024-01-05',
    category: 'Best Practices',
    tags: ['Quality Control', 'Manufacturing', 'ISO 9001'],
  },
];

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: slugify(post.title) },
    props: { post },
  }));
}

const { post } = Astro.props;

const breadcrumbItems = [
  { name: 'Blog', url: '/blog' },
  { name: post.title, url: `/blog/${slugify(post.title)}`, isCurrent: true },
];

const pageTitle = `${post.title} | YourBrand Blog`;

// Related posts (exclude current)
const relatedPosts = posts
  .filter((p) => p.id !== post.id)
  .slice(0, 3)
  .map((p) => ({
    title: p.title,
    description: p.excerpt,
    url: `/blog/${slugify(p.title)}`,
    image: p.image,
  }));
---

<Layout title={pageTitle} description={post.excerpt}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={post.excerpt} ogType="article" />
  <Schema
    slot="head"
    schema={[
      {
        type: 'Article',
        headline: post.title,
        description: post.excerpt,
        image: post.image,
        author: {
          name: post.author,
        },
        publisher: {
          name: 'YourBrand',
        },
        datePublished: post.datePublished,
      },
      {
        type: 'BreadcrumbList',
        items: [
          { name: 'Home', url: '/' },
          { name: 'Blog', url: '/blog' },
          { name: post.title, url: `/blog/${slugify(post.title)}` },
        ],
      },
    ]}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Article Header -->
  <Section class="bg-gray-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-6">
          <span class="px-3 py-1 bg-primary/10 text-primary text-sm font-medium rounded-full">
            {post.category}
          </span>
          <time class="text-gray-500 text-sm" datetime={post.datePublished}>
            {new Date(post.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6">{post.title}</h1>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold">
            {post.author.charAt(0)}
          </div>
          <div>
            <div class="font-semibold text-gray-900">{post.author}</div>
            <div class="text-sm text-gray-500">{post.authorTitle}</div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Featured Image -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
    <div class="aspect-[16/9] rounded-xl overflow-hidden shadow-lg bg-gray-100">
      <SmartImage
        src={post.image}
        alt={post.title}
        class="w-full h-full object-cover"
        aspectRatio="16/9"
        loading="eager"
      />
    </div>
  </div>

  <!-- Article Content -->
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <article class="prose prose-lg max-w-none">
          <div class="text-lg text-gray-600 leading-relaxed mb-8" set:html={post.content} />
        </article>

        <!-- Tags -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag) => (
              <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Share -->
        <div class="mt-8 flex items-center gap-4">
          <span class="text-gray-600 font-medium">Share this article:</span>
          <div class="flex gap-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`https://example.com/blog/${slugify(post.title)}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-blue-400 hover:text-white transition-colors"
              aria-label="Share on Twitter"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://example.com/blog/${slugify(post.title)}`)}&title=${encodeURIComponent(post.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-blue-700 hover:text-white transition-colors"
              aria-label="Share on LinkedIn"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Related Content -->
  <RelatedContent title="Related Articles" items={relatedPosts} />

  <!-- Inquiry CTA -->
  <InquiryCTA />
</Layout>
