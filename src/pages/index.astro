---
import Layout from '../components/layout/layout.astro';
import Container from '../components/ui/container.astro';
import Section from '../components/ui/section.astro';
import SmartImage from '../components/media/smart-image.astro';
import InquiryCTA from '../components/communication/inquiry-cta.astro';
import SEO from '../components/seo/seo.astro';
import Schema from '../components/seo/schema.astro';

const pageTitle = '外贸获客型网站系统 | 询盘云 InquiryCloud';
const pageDescription = '询盘云让您的独立站成为自动获客系统。高转化+可规模增长+可长期运营，帮您持续拿询盘的外贸独立站解决方案。';

const capabilities = [
  {
    title: '全渠道询盘获取',
    description: '即时沟通、邮件、表单、社媒引流，不丢任何一个潜在客户',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    title: '任意页面触发转化',
    description: '所有页面都可引导咨询，浏览=转化路径，而非单纯展示',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  },
  {
    title: '高转化结构设计',
    description: '产品页、服务页、博客页都带引导动作，网站=24小时销售人员',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: '内容驱动增长',
    description: '可持续增加产品页、行业文章、案例，流量持续增长而非一次性',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
  {
    title: '多语言全球覆盖',
    description: '一套系统覆盖多个国家市场，全球访问体验一致',
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: '询盘记录与追踪',
    description: '所有客户信息自动保存，客户资产沉淀，而非一次性流量',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  },
];

const features = [
  {
    step: '01',
    title: '自动获客',
    description: '全渠道询盘入口，任意页面触发转化，不丢任何一个潜在客户',
  },
  {
    step: '02',
    title: '内容增长',
    description: '可持续扩展的产品/文章/案例体系，流量持续增长',
  },
  {
    step: '03',
    title: '全球销售',
    description: '多语言覆盖，全球访问一致体验，一套系统覆盖多国市场',
  },
  {
    step: '04',
    title: '长期运营',
    description: '非技术人员可自主更新，几乎零维护成本，持续进化',
  },
];

const results = [
  {
    value: '3-5x',
    label: '询盘量提升',
    desc: '平均客户询盘增长',
  },
  {
    value: '200+',
    label: '成功部署',
    desc: '企业级获客系统',
  },
  {
    value: '98%',
    label: '客户续约',
    desc: '持续合作率',
  },
  {
    value: '24/7',
    label: '自动获客',
    desc: '全年无休运转',
  },
];

const testimonials = [
  {
    content: '询盘云让我们的独立站成为真正的获客引擎。上线3个月，询盘量翻了4倍，而且质量很高。',
    author: '张总',
    company: '某机械出口企业',
    result: '询盘量 +320%',
  },
  {
    content: '以前网站只是个展示，现在每个页面都能带来咨询。最惊喜的是SEO流量也在持续增长。',
    author: '李经理',
    company: '某家居品牌',
    result: '自然流量 +180%',
  },
  {
    content: '多语言版本帮我们打开了欧洲市场，一套系统管理所有站点，效率提升太多了。',
    author: '王总监',
    company: '某电子企业',
    result: '覆盖 5 国市场',
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'Organization',
      name: '询盘云 InquiryCloud',
      description: pageDescription,
      url: 'https://example.com',
      contactPoint: {
        telephone: '+86-400-888-8888',
        contactType: 'Sales',
        email: 'hello@xunpanyun.com',
      },
    }}
  />

  <!-- Hero Section -->
  <section class="relative min-h-[700px] lg:min-h-[800px] flex items-center">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-stone-50 via-white to-stone-100"></div>
      <div class="absolute top-20 right-20 w-64 h-64 bg-teal-100/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-20 w-48 h-48 bg-stone-200/30 rounded-full blur-3xl"></div>
    </div>
    
    <Container class="relative z-10 py-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-teal-50 text-teal-700 rounded text-sm mb-6 border border-teal-100">
            <span class="w-1.5 h-1.5 bg-teal-600 rounded-full"></span>
            外贸企业专用获客系统
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-light text-stone-800 mb-6 leading-tight tracking-tight">
            询盘云让您的独立站
            <span class="font-normal text-teal-700">成为自动获客系统</span>
          </h1>
          <p class="text-lg text-stone-500 mb-8 leading-relaxed">
            高转化 + 可规模增长 + 可长期运营。帮您持续拿询盘的外贸独立站解决方案，让每一个访客都成为潜在客户。
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-stone-800 text-white font-medium rounded hover:bg-stone-700 transition-colors"
            >
              <span>免费获取方案</span>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/cases"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white text-stone-700 font-medium rounded hover:bg-stone-50 transition-colors border border-stone-200"
            >
              <span>查看客户成果</span>
            </a>
          </div>
          
          <div class="mt-12 pt-8 border-t border-stone-200">
            <p class="text-sm text-stone-400 mb-4">已帮助 200+ 外贸企业实现获客增长</p>
            <div class="flex flex-wrap items-center gap-6">
              <div class="flex items-center gap-2 text-stone-500">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                <span class="text-sm">全渠道获客</span>
              </div>
              <div class="flex items-center gap-2 text-stone-500">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                <span class="text-sm">内容增长</span>
              </div>
              <div class="flex items-center gap-2 text-stone-500">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                <span class="text-sm">多语言覆盖</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative hidden lg:block">
          <div class="relative">
            <div class="absolute -inset-4 bg-stone-200/50 rounded-lg blur-2xl"></div>
            <div class="relative bg-white rounded-lg shadow-sm border border-stone-100 p-3">
              <SmartImage
                src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
                alt="外贸获客系统"
                class="w-full rounded"
                aspectRatio="4/3"
                loading="eager"
              />
              <div class="absolute -bottom-4 -left-4 bg-white rounded-lg shadow-sm border border-stone-100 p-4 flex items-center gap-3">
                <div class="w-10 h-10 bg-teal-50 rounded flex items-center justify-center">
                  <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-stone-400">平均询盘提升</p>
                  <p class="text-lg font-medium text-stone-700">3-5倍</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Core Value Section -->
  <Section class="bg-stone-900 text-stone-300">
    <Container>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-500 uppercase mb-3">Core Value</span>
        <h2 class="text-3xl md:text-4xl font-light text-stone-100 mb-4">
          核心价值：帮您持续拿询盘
        </h2>
        <p class="text-stone-400">
          询盘云让您的独立站成为"自动获客系统 + 内容增长系统 + 全球销售入口"
        </p>
      </div>
    </Container>
  </Section>

  <!-- Capabilities Section -->
  <Section id="capabilities" class="bg-white">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">System Capabilities</span>
        <h2 class="text-3xl md:text-4xl font-light text-stone-800 mb-4">系统能力矩阵</h2>
        <p class="text-stone-500">
          9大核心能力，打造真正能带来业务增长的外贸获客系统
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((item) => (
          <div class="group p-8 bg-stone-50 rounded border border-stone-100 hover:border-teal-200 hover:bg-teal-50/30 transition-all">
            <div class="w-12 h-12 rounded bg-white border border-stone-200 flex items-center justify-center mb-6 group-hover:border-teal-200 group-hover:bg-teal-50 transition-colors">
              <svg class="w-6 h-6 text-stone-600 group-hover:text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d={item.icon} stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">{item.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- How It Works Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">How It Works</span>
        <h2 class="text-3xl md:text-4xl font-light text-stone-800 mb-4">四大核心机制</h2>
        <p class="text-stone-500">
          从获客到增长，从本地到全球，构建完整的业务增长闭环
        </p>
      </div>
      <div class="grid md:grid-cols-4 gap-8">
        {features.map((item, index) => (
          <div class="relative text-center">
            <div class="text-5xl font-extralight text-teal-200 mb-4">{item.step}</div>
            <h3 class="text-base font-medium text-stone-800 mb-2">{item.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{item.description}</p>
            {index < features.length - 1 && (
              <div class="hidden md:block absolute top-6 left-full w-full h-px bg-stone-200"></div>
            )}
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Results Section -->
  <Section class="bg-white">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8">
        {results.map((item) => (
          <div class="text-center">
            <div class="text-4xl font-light text-teal-700 mb-1">{item.value}</div>
            <div class="text-sm font-medium text-stone-700 mb-1">{item.label}</div>
            <div class="text-xs text-stone-400">{item.desc}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Testimonials Section -->
  <Section class="bg-stone-900 text-stone-300">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-500 uppercase mb-3">Client Results</span>
        <h2 class="text-3xl md:text-4xl font-light text-stone-100 mb-4">客户真实成果</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((item) => (
          <div class="bg-stone-800/50 rounded p-8 border border-stone-700">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-2 py-1 bg-teal-900/50 text-teal-400 text-xs rounded">{item.result}</span>
            </div>
            <p class="text-stone-400 text-sm leading-relaxed mb-6">"{item.content}"</p>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-stone-700 flex items-center justify-center text-xs text-stone-400">
                {item.author[0]}
              </div>
              <div>
                <p class="text-sm text-stone-300">{item.author}</p>
                <p class="text-xs text-stone-500">{item.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Why Choose Us Section -->
  <Section>
    <Container>
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Why Us</span>
          <h2 class="text-3xl font-light text-stone-800 mb-6">为什么选择我们？</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded bg-teal-50 flex items-center justify-center flex-shrink-0">
                <span class="text-teal-600 font-medium text-sm">01</span>
              </div>
              <div>
                <h3 class="font-medium text-stone-800 mb-1">懂外贸，更懂获客</h3>
                <p class="text-stone-500 text-sm">询盘云基于外贸业务场景，帮您设计每一个转化环节</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded bg-teal-50 flex items-center justify-center flex-shrink-0">
                <span class="text-teal-600 font-medium text-sm">02</span>
              </div>
              <div>
                <h3 class="font-medium text-stone-800 mb-1">系统思维，长期价值</h3>
                <p class="text-stone-500 text-sm">从第一天就考虑可扩展性，网站可以随业务增长持续进化</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded bg-teal-50 flex items-center justify-center flex-shrink-0">
                <span class="text-teal-600 font-medium text-sm">03</span>
              </div>
              <div>
                <h3 class="font-medium text-stone-800 mb-1">数据驱动，持续优化</h3>
                <p class="text-stone-500 text-sm">每个设计决策都有数据支撑，确保最大化转化效果</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded bg-teal-50 flex items-center justify-center flex-shrink-0">
                <span class="text-teal-600 font-medium text-sm">04</span>
              </div>
              <div>
                <h3 class="font-medium text-stone-800 mb-1">交付即运营，零门槛上手</h3>
                <p class="text-stone-500 text-sm">非技术人员也能轻松更新内容，真正实现自主运营</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded overflow-hidden">
            <SmartImage
              src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80"
              alt="为什么选择我们"
              class="w-full h-full object-cover"
              aspectRatio="4/3"
            />
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Inquiry CTA -->
  <InquiryCTA />
</Layout>
