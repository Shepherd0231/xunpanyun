---
import Layout from '../../components/layout/layout.astro';
import Container from '../../components/ui/container.astro';
import Section from '../../components/ui/section.astro';
import Breadcrumbs from '../../components/ui/breadcrumbs.astro';
import SmartImage from '../../components/media/smart-image.astro';
import SEO from '../../components/seo/seo.astro';
import Schema from '../../components/seo/schema.astro';

const pageTitle = 'About Us | InquiryCloud - Lead Generation System Experts';
const pageDescription = 'InquiryCloud focuses on building high-conversion, scalable, and long-term operable lead generation website systems for foreign trade enterprises.';

const breadcrumbItems = [
  { name: 'About Us', url: '/en/about', isCurrent: true },
];

const coreValues = [
  {
    title: 'Lead Generation First',
    description: 'Every design decision centers on conversion - every page is a lead entry point, not just display',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  },
  {
    title: 'System Thinking',
    description: 'Scalability considered from day one - website evolves with your business growth',
    icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  },
  {
    title: 'Long-term Value',
    description: 'Website is an asset, not a project - continuously generates value',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Data-Driven',
    description: 'Every decision backed by data, continuously optimizing conversion',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
];

const stats = [
  { value: '200+', label: 'Systems Deployed', desc: 'Enterprise solutions' },
  { value: '3-5x', label: 'Avg Lead Increase', desc: 'Real client data' },
  { value: '98%', label: 'Retention Rate', desc: 'Long-term partnerships' },
  { value: '50+', label: 'Countries', desc: 'Global market service' },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'Organization',
      name: 'InquiryCloud',
      description: pageDescription,
      url: 'https://example.com',
    }}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">About Us</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">
          Transform Your Website Into an
          <span class="text-teal-700">Automated Lead System</span>
        </h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          InquiryCloud focuses on lead generation needs of foreign trade enterprises, transforming websites from "display tools" to "automated lead systems"
        </p>
      </div>
    </Container>
  </Section>

  <!-- Mission Section -->
  <Section>
    <Container>
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Our Mission</span>
          <h2 class="text-3xl font-light text-stone-800 mb-6">Our Mission</h2>
          <div class="space-y-4 text-stone-500 leading-relaxed">
            <p>
              The biggest problem with traditional foreign trade websites: you spend money building them, but get no leads. The website becomes decoration, not a business growth engine.
            </p>
            <p>
              We redefined the value of foreign trade websites — <strong class="text-stone-700">it should be an automated lead generation system</strong>. From day one, we designed every feature, every page, every interaction around "how to continuously get leads".
            </p>
            <p>
              Over 5 years, we've served 200+ foreign trade enterprises, helping them build website systems that truly drive business growth. Average lead volume increased 3-5x, with a 98% client retention rate.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded overflow-hidden">
            <SmartImage
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80"
              alt="InquiryCloud Team"
              class="w-full h-full object-cover"
              aspectRatio="4/3"
            />
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Core Values Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Core Values</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">Core Values</h2>
        <p class="text-stone-500">
          These principles guide every decision we make, ensuring real business value for our clients
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {coreValues.map((value) => (
          <div class="bg-white p-8 rounded border border-stone-100">
            <div class="w-12 h-12 rounded bg-teal-50 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d={value.icon} stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">{value.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Stats Section -->
  <Section>
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl font-light text-teal-700 mb-1">{stat.value}</div>
            <div class="text-sm font-medium text-stone-700 mb-1">{stat.label}</div>
            <div class="text-xs text-stone-400">{stat.desc}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>
</Layout>
