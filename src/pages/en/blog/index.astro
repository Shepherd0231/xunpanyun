---
import Layout from '../../../components/layout/layout.astro';
import Container from '../../../components/ui/container.astro';
import Section from '../../../components/ui/section.astro';
import Breadcrumbs from '../../../components/ui/breadcrumbs.astro';
import SmartImage from '../../../components/media/smart-image.astro';
import SEO from '../../../components/seo/seo.astro';
import Schema from '../../../components/seo/schema.astro';

const pageTitle = 'Blog | InquiryCloud';
const pageDescription = 'Read the latest articles from InquiryCloud about independent website design, SEO optimization, and e-commerce operations.';

const breadcrumbItems = [
  { name: 'Blog', url: '/en/blog/', isCurrent: true },
];

const categories = [
  { id: 'all', name: 'All' },
  { id: 'design', name: 'Design' },
  { id: 'seo', name: 'SEO' },
  { id: 'ecommerce', name: 'E-commerce' },
  { id: 'marketing', name: 'Marketing' },
];

const posts = [
  {
    id: 1,
    title: '2024 Foreign Trade Website Design Trends: Perfect Balance of Minimalism and Function',
    excerpt: 'Explore the most popular foreign trade website design trends this year, from minimalism to micro-interactions, learn how to make your...',
    category: 'design',
    categoryName: 'Design',
    date: '2024-03-15',
    readTime: '5 min',
    image: 'https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?w=600&q=80',
    slug: 'web-design-trends-2024',
  },
  {
    id: 2,
    title: 'B2B E-commerce Website Design: From Product Display to Inquiry Conversion',
    excerpt: 'In-depth analysis of B2B e-commerce website design essentials, from product display to inquiry conversion, building high-conversion lead generation sites...',
    category: 'ecommerce',
    categoryName: 'E-commerce',
    date: '2024-03-10',
    readTime: '8 min',
    image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&q=80',
    slug: 'b2b-ecommerce-design-guide',
  },
  {
    id: 3,
    title: 'Complete SEO Guide for Foreign Trade Websites: From Basics to Advanced',
    excerpt: 'Systematic explanation of core SEO strategies for foreign trade websites, including keyword research, technical SEO, content optimization...',
    category: 'seo',
    categoryName: 'SEO',
    date: '2024-03-05',
    readTime: '12 min',
    image: 'https://images.unsplash.com/photo-1572177812156-58036aae439c?w=600&q=80',
    slug: 'seo-optimization-guide',
  },
  {
    id: 4,
    title: '10 Design Principles for High-Converting Landing Pages',
    excerpt: 'Data-driven design principles to help you create marketing landing pages with doubled conversion rates...',
    category: 'marketing',
    categoryName: 'Marketing',
    date: '2024-02-28',
    readTime: '6 min',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80',
    slug: 'landing-page-design-principles',
  },
  {
    id: 5,
    title: 'Website Performance Optimization: How to Improve Loading Speed by 50%',
    excerpt: 'In-depth explanation of website performance optimization techniques, from image compression to code optimization, comprehensively improving user experience...',
    category: 'design',
    categoryName: 'Design',
    date: '2024-02-20',
    readTime: '7 min',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80',
    slug: 'website-performance-optimization',
  },
  {
    id: 6,
    title: 'Google Ads Guide: Practical Tips for Driving Traffic to Independent Sites',
    excerpt: 'From account setup to ad optimization, comprehensive guide on how to drive targeted traffic to independent sites through Google Ads...',
    category: 'marketing',
    categoryName: 'Marketing',
    date: '2024-02-15',
    readTime: '10 min',
    image: 'https://images.unsplash.com/photo-1432888498266-38ffec3eaf0a?w=600&q=80',
    slug: 'google-ads-guide',
  },
];

const featuredPost = posts[0];
---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'Blog',
      name: 'InquiryCloud Blog',
      description: pageDescription,
    }}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Blog</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">Blog Articles</h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          Sharing practical experience and industry insights on independent website design, SEO optimization, and e-commerce operations
        </p>
      </div>
    </Container>
  </Section>

  <!-- Featured Post Section -->
  <Section>
    <Container>
      <div class="grid lg:grid-cols-2 gap-8 items-center bg-white rounded border border-stone-100 overflow-hidden">
        <div class="aspect-[16/10] lg:aspect-auto lg:h-full">
          <SmartImage
            src={featuredPost.image}
            alt={featuredPost.title}
            class="w-full h-full object-cover"
            aspectRatio="16/10"
          />
        </div>
        <div class="p-8 lg:p-12">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-2 py-1 bg-teal-50 text-teal-600 text-xs rounded">{featuredPost.categoryName}</span>
            <span class="text-stone-400 text-xs">{featuredPost.date}</span>
          </div>
          <h2 class="text-2xl font-light text-stone-800 mb-4">{featuredPost.title}</h2>
          <p class="text-stone-500 mb-6 leading-relaxed">{featuredPost.excerpt}</p>
          <div class="flex items-center justify-between">
            <span class="text-stone-400 text-sm">Read time: {featuredPost.readTime}</span>
            <a
              href={`/en/blog/${featuredPost.slug}/`}
              class="inline-flex items-center gap-2 text-stone-800 font-medium hover:text-teal-600 transition-colors"
            >
              <span>Read Full Article</span>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Posts Section -->
  <Section class="bg-stone-50">
    <Container>
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        {categories.map((category) => (
          <button
            class="px-4 py-2 text-sm rounded border border-stone-200 text-stone-600 hover:border-stone-400 hover:text-stone-800 transition-colors"
            data-category={category.id}
          >
            {category.name}
          </button>
        ))}
      </div>

      <!-- Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.slice(1).map((post) => (
          <article class="group bg-white rounded border border-stone-100 overflow-hidden hover:border-stone-200 transition-all" data-post-category={post.category}>
            <div class="aspect-[16/10] overflow-hidden">
              <SmartImage
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                aspectRatio="16/10"
              />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs text-teal-600">{post.categoryName}</span>
                <span class="text-stone-300">·</span>
                <span class="text-stone-400 text-xs">{post.date}</span>
              </div>
              <h3 class="text-lg font-medium text-stone-800 mb-2 line-clamp-2 group-hover:text-teal-600 transition-colors">
                <a href={`/en/blog/${post.slug}/`}>{post.title}</a>
              </h3>
              <p class="text-stone-500 text-sm mb-4 line-clamp-2">{post.excerpt}</p>
              <div class="flex items-center justify-between">
                <span class="text-stone-400 text-xs">{post.readTime} read</span>
                <a
                  href={`/en/blog/${post.slug}/`}
                  class="text-sm text-stone-600 hover:text-teal-600 transition-colors"
                >
                  Read more →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Load More Button -->
      <div class="text-center mt-12">
        <button
          class="inline-flex items-center gap-2 px-6 py-3 border border-stone-300 text-stone-600 font-medium rounded hover:border-stone-400 hover:text-stone-800 transition-colors"
        >
          <span>Load More Articles</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
      </div>
    </Container>
  </Section>

  <!-- Newsletter Section -->
  <Section>
    <Container>
      <div class="max-w-2xl mx-auto text-center py-8">
        <h2 class="text-2xl font-light text-stone-800 mb-4">Subscribe to Our Blog</h2>
        <p class="text-stone-500 mb-8">
          Get the latest independent website design tips, SEO strategies, and e-commerce operation insights
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Enter your email address"
            class="flex-1 px-4 py-3 border border-stone-200 rounded focus:ring-1 focus:ring-stone-400 focus:border-stone-400 transition-colors text-sm"
            required
          />
          <button
            type="submit"
            class="px-6 py-3 bg-stone-800 text-white font-medium rounded hover:bg-stone-700 transition-colors text-sm"
          >
            Subscribe Now
          </button>
        </form>
        <p class="text-stone-400 text-xs mt-4">We respect your privacy and will not send spam</p>
      </div>
    </Container>
  </Section>
</Layout>

<script>
  const categoryButtons = document.querySelectorAll('[data-category]');
  const postCards = document.querySelectorAll('[data-post-category]');

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      
      categoryButtons.forEach((btn) => {
        btn.classList.toggle('bg-teal-50', btn.getAttribute('data-category') === category);
        btn.classList.toggle('text-teal-700', btn.getAttribute('data-category') === category);
        btn.classList.toggle('border-teal-300', btn.getAttribute('data-category') === category);
      });

      postCards.forEach((card) => {
        const cardCategory = card.getAttribute('data-post-category');
        if (category === 'all' || cardCategory === category) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
