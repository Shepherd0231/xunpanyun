---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'CollectionPage',
      name: 'InquiryCloud Client Results',
      description: pageDescription,
    }}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Client Results</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">
          Real Client Results
          <span class="text-teal-700">Data Speaks</span>
        </h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          From 3-5x inquiry growth to global market expansion, these are the real results our clients have achieved
        </p>
      </div>
    </Container>
  </Section>

  <!-- Stats Section -->
  <Section class="bg-white">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl md:text-5xl font-light text-teal-700 mb-2">{stat.value}</div>
            <div class="text-base font-medium text-stone-700 mb-1">{stat.label}</div>
            <div class="text-sm text-stone-400">{stat.desc}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Category Filter -->
  <Section class="bg-stone-50">
    <Container>
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {categories.map((cat) => (
          <button
            type="button"
            class="px-5 py-2 text-sm rounded border border-stone-200 bg-white text-stone-600 hover:border-teal-300 hover:text-teal-700 transition-colors"
            data-category={cat.id}
          >
            {cat.name}
          </button>
        ))}
      </div>

      <!-- Cases Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {cases.map((caseItem) => (
          <article class="group bg-white rounded border border-stone-100 overflow-hidden hover:shadow-lg transition-shadow" data-category={caseItem.category}>
            <div class="aspect-[4/3] overflow-hidden">
              <SmartImage
                src={caseItem.image}
                alt={caseItem.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                aspectRatio="4/3"
              />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs text-teal-600 bg-teal-50 px-2 py-1 rounded">{caseItem.categoryName}</span>
              </div>
              <h3 class="text-xl font-medium text-stone-800 mb-2">{caseItem.title}</h3>
              <p class="text-stone-500 text-sm leading-relaxed mb-4">{caseItem.description}</p>
              
              <!-- Results -->
              <div class="grid grid-cols-2 gap-4 mb-4 p-4 bg-stone-50 rounded">
                {caseItem.results.map((result) => (
                  <div>
                    <div class="text-xs text-stone-400 mb-1">{result.label}</div>
                    <div class="flex items-baseline gap-2">
                      <span class="text-lg font-medium text-teal-700">{result.value}</span>
                      <span class="text-xs text-stone-400 line-through">{result.before}</span>
                    </div>
                  </div>
                ))}
              </div>

              <!-- Metrics -->
              <div class="flex flex-wrap gap-2 mb-4">
                {caseItem.metrics.map((metric) => (
                  <span class="text-xs text-stone-500 bg-stone-100 px-2 py-1 rounded">
                    {metric.label}: <span class="text-teal-600 font-medium">{metric.value}</span>
                  </span>
                ))}
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {caseItem.tags.map((tag) => (
                  <span class="text-xs text-stone-400">#{tag}</span>
                ))}
              </div>

              <!-- Testimonial -->
              <blockquote class="border-l-2 border-teal-300 pl-4 py-2 bg-stone-50">
                <p class="text-sm text-stone-600 italic mb-2">"{caseItem.testimonial}"</p>
                <footer class="text-xs text-stone-400">— {caseItem.client}</footer>
              </blockquote>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Methodology Section -->
  <Section class="bg-white">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Our Methodology</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">How We Deliver Results</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-8">
        {methodology.map((item) => (
          <div class="text-center">
            <div class="text-5xl font-extralight text-teal-200 mb-4">{item.step}</div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">{item.title}</h3>
            <p class="text-stone-500 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- CTA Section -->
  <Section class="bg-stone-900 text-stone-300">
    <Container>
      <div class="text-center max-w-2xl mx-auto py-8">
        <h2 class="text-3xl font-light text-stone-100 mb-4">
          Want Similar Results?
        </h2>
        <p class="text-stone-400 mb-8">
          Contact us for a free consultation and customized lead generation solution
        </p>
        <a
          href="/en/contact/"
          class="inline-flex items-center gap-2 px-8 py-3 bg-stone-100 text-stone-800 font-medium rounded hover:bg-white transition-colors"
        >
          <span>Get Free Consultation</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </Container>
  </Section>
</Layout>

<script>
  const categoryButtons = document.querySelectorAll('[data-category]');
  const caseCards = document.querySelectorAll('article[data-category]');

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      
      categoryButtons.forEach((btn) => {
        btn.classList.toggle('bg-teal-50', btn.getAttribute('data-category') === category);
        btn.classList.toggle('text-teal-700', btn.getAttribute('data-category') === category);
        btn.classList.toggle('border-teal-300', btn.getAttribute('data-category') === category);
      });

      caseCards.forEach((card) => {
        const cardCategory = card.getAttribute('data-category');
        if (category === 'all' || cardCategory === category) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
