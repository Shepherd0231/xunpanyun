const stats = [
  { value: '200+', label: '获客系统部署', desc: '企业级解决方案' },
  { value: '3-5x', label: '平均询盘提升', desc: '客户真实数据' },
  { value: '98%', label: '客户满意度', desc: '持续合作关系' },
  { value: '50+', label: '覆盖国家', desc: '全球市场服务' },
];

const methodology = [
  {
    step: '01',
    title: '获客诊断',
    desc: '分析现有获客渠道，找出增长机会',
  },
  {
    step: '02',
    title: '系统设计',
    desc: '基于业务场景设计转化路径',
  },
  {
    step: '03',
    title: '开发部署',
    desc: '高转化网站系统开发上线',
  },
  {
    step: '04',
    title: '持续优化',
    desc: '数据驱动，不断提升获客效果',
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'CollectionPage',
      name: '询盘云 InquiryCloud 客户成果',
      description: pageDescription,
    }}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Client Results</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">
          客户真实成果
          <span class="text-teal-700">数据说话</span>
        </h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          平均询盘量提升3-5倍，帮助200+外贸企业实现获客增长
        </p>
      </div>
    </Container>
  </Section>

  <!-- Stats Section -->
  <Section class="bg-white border-b border-stone-100">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-light text-teal-700 mb-1">{stat.value}</div>
            <div class="text-sm font-medium text-stone-700 mb-1">{stat.label}</div>
            <div class="text-xs text-stone-400">{stat.desc}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Cases Section -->
  <Section>
    <Container>
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        {categories.map((category) => (
          <button
            class="px-4 py-2 text-sm rounded border border-stone-200 text-stone-600 hover:border-stone-400 hover:text-stone-800 transition-colors"
            data-category={category.id}
          >
            {category.name}
          </button>
        ))}
      </div>

      <!-- Cases Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {cases.map((caseItem) => (
          <div class="group bg-white rounded border border-stone-100 overflow-hidden hover:border-teal-200 transition-all" data-case-category={caseItem.category}>
            <div class="aspect-[4/3] overflow-hidden">
              <SmartImage
                src={caseItem.image}
                alt={caseItem.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                aspectRatio="4/3"
              />
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs text-teal-600">{caseItem.categoryName}</span>
              </div>
              <h3 class="text-lg font-medium text-stone-800 mb-2">{caseItem.title}</h3>
              <p class="text-stone-500 text-sm mb-4 line-clamp-2">{caseItem.description}</p>
              
              <!-- Main Results -->
              <div class="flex gap-4 mb-4 pb-4 border-b border-stone-100">
                {caseItem.results.map((result) => (
                  <div>
                    <div class="text-lg font-medium text-teal-700">{result.value}</div>
                    <div class="text-xs text-stone-400">{result.label}</div>
                  </div>
                ))}
              </div>

              <!-- Metrics -->
              <div class="grid grid-cols-3 gap-2 mb-4">
                {caseItem.metrics.map((metric) => (
                  <div class="text-center p-2 bg-stone-50 rounded">
                    <div class="text-sm font-medium text-stone-700">{metric.value}</div>
                    <div class="text-xs text-stone-400">{metric.label}</div>
                  </div>
                ))}
              </div>

              <!-- Testimonial -->
              <div class="bg-stone-50 p-3 rounded mb-4">
                <p class="text-stone-500 text-xs italic">"{caseItem.testimonial}"</p>
                <p class="text-stone-400 text-xs mt-2">— {caseItem.client}</p>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {caseItem.tags.map((tag) => (
                  <span class="px-2 py-1 bg-stone-50 text-stone-500 text-xs rounded">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Methodology Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Our Methodology</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">我们的方法论</h2>
        <p class="text-stone-500">
          每个成功案例背后，都有我们系统化的获客方法论支撑
        </p>
      </div>
      <div class="grid md:grid-cols-4 gap-8">
        {methodology.map((item) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white border border-stone-200 flex items-center justify-center">
              <span class="text-2xl font-extralight text-teal-200">{item.step}</span>
            </div>
            <h3 class="text-sm font-medium text-stone-800 mb-2">{item.title}</h3>
            <p class="text-stone-500 text-xs">{item.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- CTA Section -->
  <Section class="bg-stone-900 text-stone-300">
    <Container>
      <div class="text-center max-w-2xl mx-auto py-8">
        <h2 class="text-3xl font-light text-stone-100 mb-4">想成为我们的下一个成功案例吗？</h2>
        <p class="text-stone-400 mb-8">
          联系我们，开启您的自动获客之旅
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-3 bg-stone-100 text-stone-800 font-medium rounded hover:bg-white transition-colors"
        >
          <span>免费获取方案</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </Container>
  </Section>
</Layout>

<script>
  // Simple category filter
  const filterButtons = document.querySelectorAll('[data-category]');
  const caseItems = document.querySelectorAll('[data-case-category]');

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      
      // Update active state
      filterButtons.forEach((btn) => {
        btn.classList.remove('bg-stone-800', 'text-white', 'border-stone-800');
        btn.classList.add('border-stone-200', 'text-stone-600');
      });
      button.classList.remove('border-stone-200', 'text-stone-600');
      button.classList.add('bg-stone-800', 'text-white', 'border-stone-800');

      // Filter cases
      caseItems.forEach((item) => {
        if (category === 'all' || item.getAttribute('data-case-category') === category) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // Set first button as active by default
  if (filterButtons.length > 0) {
    filterButtons[0].classList.remove('border-stone-200', 'text-stone-600');
    filterButtons[0].classList.add('bg-stone-800', 'text-white', 'border-stone-800');
  }
</script>
