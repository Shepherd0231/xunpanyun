---
import Layout from '../components/layout/layout.astro';
import Container from '../components/ui/container.astro';
import Section from '../components/ui/section.astro';
import Breadcrumbs from '../components/ui/breadcrumbs.astro';
import SmartImage from '../components/media/smart-image.astro';
import SEO from '../components/seo/seo.astro';
import Schema from '../components/seo/schema.astro';

const pageTitle = '关于我们 | 询盘云 InquiryCloud - 外贸获客系统专家';
const pageDescription = '询盘云专注于打造高转化、可规模增长、可长期运营的外贸获客型网站系统，帮助企业持续获取询盘。';

const breadcrumbItems = [
  { name: '关于我们', url: '/about', isCurrent: true },
];

const coreValues = [
  {
    title: '获客优先',
    description: '一切设计以转化为核心，每个页面都是获客入口，而非单纯展示',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  },
  {
    title: '系统思维',
    description: '从第一天就考虑可扩展性，网站可以随业务增长持续进化',
    icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  },
  {
    title: '长期价值',
    description: '网站是资产而非项目，持续产生价值，而非一次性交付',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: '数据驱动',
    description: '每个决策都有数据支撑，持续优化转化效果',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
];

const capabilities = [
  {
    number: '01',
    title: '获客与转化能力',
    items: [
      '全渠道询盘获取（聊天/邮件/表单/社媒）',
      '任意页面触发转化机制',
      '高转化结构设计与CTA布局',
      '24小时自动获客运转',
    ],
  },
  {
    number: '02',
    title: '内容驱动增长',
    items: [
      '可持续扩展的内容架构',
      '自动形成内容网络',
      '从几十页到上千页的规模化能力',
      'SEO友好的内容体系',
    ],
  },
  {
    number: '03',
    title: '全球化业务支撑',
    items: [
      '多语言市场覆盖',
      '全球访问一致体验',
      'CDN加速，降低客户流失',
      '本地化SEO优化',
    ],
  },
  {
    number: '04',
    title: '品牌信任构建',
    items: [
      '完整企业展示体系',
      '专业形象输出',
      '客户评价与案例展示',
      '资质认证与信任背书',
    ],
  },
];

const milestones = [
  { year: '2019', title: '系统架构诞生', description: '基于外贸业务场景，设计第一代获客型网站架构' },
  { year: '2020', title: '首批客户验证', description: '服务首批50家企业，平均询盘提升200%' },
  { year: '2021', title: '技术栈升级', description: '全面采用现代化技术，性能提升300%' },
  { year: '2022', title: '多语言系统', description: '推出多语言版本，助力客户开拓全球市场' },
  { year: '2023', title: 'AI辅助优化', description: '引入AI分析，持续优化转化效果' },
  { year: '2024', title: '系统3.0发布', description: '全新架构，更强的获客能力和扩展性' },
];

const stats = [
  { value: '200+', label: '获客系统部署', desc: '企业级解决方案' },
  { value: '3-5x', label: '平均询盘提升', desc: '客户真实数据' },
  { value: '98%', label: '客户续约率', desc: '长期合作关系' },
  { value: '50+', label: '覆盖国家', desc: '全球市场服务' },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <SEO slot="head" seoTitle={pageTitle} seoDescription={pageDescription} ogType="website" />
  <Schema
    slot="head"
    schema={{
      type: 'Organization',
      name: '询盘云 InquiryCloud',
      description: pageDescription,
      url: 'https://example.com',
    }}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">About Us</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">
          询盘云让您的独立站
          <span class="text-teal-700">成为自动获客系统</span>
        </h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          询盘云专注于外贸企业的获客需求，将网站从"展示工具"升级为"自动获客系统 + 内容增长系统 + 全球销售入口"
        </p>
      </div>
    </Container>
  </Section>

  <!-- Mission Section -->
  <Section>
    <Container>
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Our Mission</span>
          <h2 class="text-3xl font-light text-stone-800 mb-6">我们的使命</h2>
          <div class="space-y-4 text-stone-500 leading-relaxed">
            <p>
              传统外贸网站最大的问题是：花了钱做了网站，却拿不到询盘。网站成了摆设，而不是业务增长的引擎。
            </p>
            <p>
              我们重新定义了外贸网站的价值——<strong class="text-stone-700">它应该是一个自动获客系统</strong>。从第一天开始，我们就围绕"如何持续拿询盘"来设计每一个功能、每一个页面、每一个交互。
            </p>
            <p>
              5年来，我们服务了200+外贸企业，帮助他们构建了真正能带来业务增长的网站系统。平均询盘量提升3-5倍，客户续约率高达98%。
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded overflow-hidden">
            <SmartImage
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80"
              alt="询盘云团队"
              class="w-full h-full object-cover"
              aspectRatio="4/3"
            />
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Core Values Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Core Values</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">核心价值观</h2>
        <p class="text-stone-500">
          这些原则指导着我们的每一个决策，确保为客户创造真正的业务价值
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {coreValues.map((value) => (
          <div class="bg-white p-8 rounded border border-stone-100">
            <div class="w-12 h-12 rounded bg-teal-50 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d={value.icon} stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">{value.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Capabilities Section -->
  <Section>
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">System Capabilities</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">系统能力矩阵</h2>
        <p class="text-stone-500">
          9大核心能力，打造真正能带来业务增长的外贸获客系统
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {capabilities.map((item) => (
          <div class="bg-stone-50 p-8 rounded border border-stone-100">
            <div class="flex items-start gap-4">
              <span class="text-3xl font-extralight text-teal-200">{item.number}</span>
              <div>
                <h3 class="text-lg font-medium text-stone-800 mb-4">{item.title}</h3>
                <ul class="space-y-2">
                  {item.items.map((listItem) => (
                    <li class="flex items-start gap-2 text-sm text-stone-500">
                      <svg class="w-4 h-4 text-teal-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                      </svg>
                      <span>{listItem}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Milestones Section -->
  <Section class="bg-stone-900 text-stone-300">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-500 uppercase mb-3">Milestones</span>
        <h2 class="text-3xl font-light text-stone-100 mb-4">发展历程</h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-stone-700"></div>
          <div class="space-y-8">
            {milestones.map((milestone) => (
              <div class="relative pl-12">
                <div class="absolute left-2 top-1.5 w-5 h-5 rounded-full bg-teal-900 border-2 border-teal-700"></div>
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4">
                  <span class="text-teal-500 font-medium">{milestone.year}</span>
                  <div>
                    <h3 class="text-stone-200 font-medium mb-1">{milestone.title}</h3>
                    <p class="text-stone-500 text-sm">{milestone.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Stats Section -->
  <Section class="bg-white">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl font-light text-teal-700 mb-1">{stat.value}</div>
            <div class="text-sm font-medium text-stone-700 mb-1">{stat.label}</div>
            <div class="text-xs text-stone-400">{stat.desc}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Why Different Section -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Why Different</span>
        <h2 class="text-3xl font-light text-stone-800 mb-4">我们有什么不同？</h2>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded border border-stone-100">
            <h3 class="text-stone-400 text-sm mb-4">传统建站公司</h3>
            <ul class="space-y-3">
              <li class="flex items-center gap-2 text-stone-500 text-sm">
                <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                关注设计美观，忽视转化效果
              </li>
              <li class="flex items-center gap-2 text-stone-500 text-sm">
                <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                交付后难以扩展和更新
              </li>
              <li class="flex items-center gap-2 text-stone-500 text-sm">
                <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                网站做完就结束，无后续价值
              </li>
              <li class="flex items-center gap-2 text-stone-500 text-sm">
                <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                不懂外贸业务场景
              </li>
            </ul>
          </div>
          <div class="bg-teal-900 text-white p-8 rounded">
            <h3 class="text-teal-300 text-sm mb-4">询盘云 InquiryCloud</h3>
            <ul class="space-y-3">
              <li class="flex items-center gap-2 text-stone-200 text-sm">
                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                以获客为核心，每个设计都服务于转化
              </li>
              <li class="flex items-center gap-2 text-stone-200 text-sm">
                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                可扩展架构，从几十页到上千页
              </li>
              <li class="flex items-center gap-2 text-stone-200 text-sm">
                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                网站是资产，持续产生价值
              </li>
              <li class="flex items-center gap-2 text-stone-200 text-sm">
                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                深耕外贸，懂业务更懂获客
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </Section>
</Layout>
