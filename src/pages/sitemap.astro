---
import Layout from '../components/layout/layout.astro';
import Container from '../components/ui/container.astro';
import Section from '../components/ui/section.astro';
import Breadcrumbs from '../components/ui/breadcrumbs.astro';
import SEO from '../components/seo/seo.astro';
import Schema from '../components/seo/schema.astro';

const pageTitle = '网站地图 | 询盘云 InquiryCloud';
const pageDescription = '询盘云网站地图，快速找到您需要的页面和服务信息。';

const breadcrumbItems = [
  { name: '网站地图', url: '/sitemap', isCurrent: true },
];

const siteSections = [
  {
    title: '主要页面',
    links: [
      { label: '首页', href: '/', description: '高转化外贸获客系统' },
      { label: '关于我们', href: '/about', description: '了解询盘云团队与理念' },
      { label: '服务', href: '/services', description: '外贸获客系统服务' },
      { label: '案例', href: '/cases', description: '客户成功故事' },
      { label: '博客', href: '/blog', description: '行业资讯与知识' },
      { label: '联系我们', href: '/contact', description: '获取免费咨询' },
    ],
  },
  {
    title: '服务项目',
    links: [
      { label: '获客型网站系统搭建', href: '/services', description: '全渠道询盘获取系统' },
      { label: '电商获客系统', href: '/services', description: 'B2B电商获客解决方案' },
      { label: '多语言全球获客系统', href: '/services', description: '覆盖全球市场' },
      { label: '网站获客能力升级', href: '/services', description: '现有网站改造升级' },
    ],
  },
  {
    title: '博客文章',
    links: [
      { label: '2024年外贸独立站设计趋势', href: '/blog/web-design-trends-2024', description: '简约与功能的完美平衡' },
      { label: '外贸B2B电商网站设计指南', href: '/blog/b2b-ecommerce-design-guide', description: '从产品展示到询盘转化' },
      { label: '外贸网站SEO优化完全指南', href: '/blog/seo-optimization-guide', description: '从基础到进阶' },
    ],
  },
  {
    title: '案例展示',
    links: [
      { label: '华锐机械获客系统', href: '/cases', description: '工业机械制造商案例' },
      { label: '悦享家居电商获客', href: '/cases', description: '家居电商获客案例' },
      { label: '智云科技多语言获客', href: '/cases', description: '多语言网站案例' },
    ],
  },
  {
    title: '法律信息',
    links: [
      { label: '隐私政策', href: '/privacy', description: '个人信息保护政策' },
      { label: '服务条款', href: '/terms', description: '服务使用条款' },
      { label: '网站地图', href: '/sitemap', description: '本站所有页面导航' },
    ],
  },
];
---

<Layout>
  <SEO title={pageTitle} description={pageDescription} />
  
  <Section class="bg-stone-50">
    <Container>
      <Breadcrumbs items={breadcrumbItems} />
      
      <div class="text-center max-w-3xl mx-auto py-12">
        <span class="inline-block text-xs tracking-widest text-stone-400 uppercase mb-3">Sitemap</span>
        <h1 class="text-4xl md:text-5xl font-light text-stone-800 mb-6">
          网站地图
        </h1>
        <p class="text-lg text-stone-500 leading-relaxed">
          快速找到您需要的页面和服务信息
        </p>
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
        {siteSections.map((section) => (
          <div class="bg-white p-6 rounded-lg border border-stone-100">
            <h2 class="text-lg font-medium text-stone-800 mb-4 pb-3 border-b border-stone-100">
              {section.title}
            </h2>
            <ul class="space-y-3">
              {section.links.map((link) => (
                <li>
                  <a 
                    href={link.href} 
                    class="group block"
                  >
                    <span class="text-stone-700 group-hover:text-teal-600 transition-colors font-medium">
                      {link.label}
                    </span>
                    <span class="block text-sm text-stone-400 mt-0.5">
                      {link.description}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- CTA Section -->
  <Section class="bg-stone-900">
    <Container>
      <div class="text-center py-12">
        <h2 class="text-2xl md:text-3xl font-light text-white mb-4">
          没有找到您需要的信息？
        </h2>
        <p class="text-stone-400 mb-8 max-w-xl mx-auto">
          我们的团队随时准备为您解答疑问，提供专业的咨询服务
        </p>
        <a 
          href="/contact" 
          class="inline-flex items-center gap-2 bg-teal-600 text-white px-8 py-3 rounded hover:bg-teal-700 transition-colors"
        >
          联系我们
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Container>
  </Section>
</Layout>
